{
  "name": "claude-assistant",
  "version": "1.0.0",
  "description": "Claude Assistant for macOS",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --mac"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.claude.assistant",
    "productName": "Claude Assistant",
    "directories": {
      "output": "dist"
    },
    "mac": {
      "category": "public.app-category.productivity",
      "target": "dmg"
    },
    "dmg": {
      "title": "Claude Assistant"
    }
  }
}
